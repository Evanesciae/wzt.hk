{
  "name": "wzt-hk",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 node --env-file-if-exists=.env ./node_modules/astro/bin/astro.mjs dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "start": "node ./dist/server/entry.mjs",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "admin:password": "node ./scripts/hash-password.mjs",
    "backup": "sh ./scripts/backup.sh",
    "data:pull": "sh ./scripts/pull-data.sh",
    "data:push": "sh ./scripts/push-data.sh",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.4",
    "@node-rs/argon2": "^2.0.2",
    "astro": "^6.0.0",
    "exifr": "^7.1.3",
    "maplibre-gl": "^5.24.0",
    "marked": "^18.0.5",
    "sharp": "^0.35.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@types/node": "^26.1.0",
    "typescript": "^5.9.0"
  }
}
