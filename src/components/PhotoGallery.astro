---
import type { TravelPhoto } from '../server/types';
type GalleryPhoto = TravelPhoto & {
  dateLabel: string;
  eventTitle: string;
};

interface Props { photos: GalleryPhoto[] }
const { photos } = Astro.props;
const prepared = photos.map((photo) => {
  const variants = [...photo.variants].sort((a, b) => a.width - b.width);
  return { ...photo, thumb: variants[Math.min(1, variants.length - 1)], full: variants.at(-1), variants };
});
---

<div class="photo-gallery" data-photo-gallery>
  {prepared.map((photo, index) => (
    <button
      class:list={['gallery-photo', index === 0 && 'gallery-photo-featured']}
      type="button"
      data-photo-src={photo.full ? `/media/${photo.full.path}` : ''}
      data-photo-alt={photo.alt}
      data-photo-caption={photo.caption ?? `${photo.dateLabel} · ${photo.eventTitle}`}
    >
      {photo.thumb && <img
        src={`/media/${photo.thumb.path}`}
        srcset={photo.variants.map((variant) => `/media/${variant.path} ${variant.width}w`).join(', ')}
        sizes="(max-width: 600px) 50vw, 30vw" alt={photo.alt} loading="lazy" decoding="async"
      />}
    </button>
  ))}
  <dialog class="photo-dialog" data-photo-dialog>
    <button type="button" class="dialog-close" data-dialog-close aria-label="关闭照片">×</button>
    <img data-dialog-image alt="" />
    <p data-dialog-caption></p>
  </dialog>
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-photo-gallery]').forEach((gallery) => {
    const dialog = gallery.querySelector<HTMLDialogElement>('[data-photo-dialog]');
    const image = dialog?.querySelector<HTMLImageElement>('[data-dialog-image]');
    const caption = dialog?.querySelector<HTMLElement>('[data-dialog-caption]');
    gallery.querySelectorAll<HTMLButtonElement>('[data-photo-src]').forEach((button) => {
      button.addEventListener('click', () => {
        if (!dialog || !image) return;
        image.src = button.dataset.photoSrc ?? '';
        image.alt = button.dataset.photoAlt ?? '';
        if (caption) caption.textContent = button.dataset.photoCaption ?? '';
        dialog.showModal();
      });
    });
    dialog?.querySelector<HTMLButtonElement>('[data-dialog-close]')?.addEventListener('click', () => dialog.close());
    dialog?.addEventListener('click', (event) => { if (event.target === dialog) dialog.close(); });
  });
</script>
